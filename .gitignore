# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
test_debug.txt
afterclose.db
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Unused desktop platforms (can regenerate with: flutter create --platforms=linux,windows .)
/linux/
/windows/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Eclipse/Buildship IDE generated files
android/.project
android/.settings/

# Golden test failure artifacts (debug only, not for version control)
test/**/failures/

# Environment variables
.env
.env.*
!.env.example

# Stage 3+4 calibration artifacts (local dev machine only, never committed)
tool/calibration.db
tool/calibration.db-*
tool/calibrate-*.log

# recalibrate.dart 的 candidate 輸出（人工 review 後 rename 成 production
# 檔名才提交；candidate 是 stale 中間產物，誤入 commit 會污染 diff）
assets/*_candidate.json
backfill.log
replay.log
backfill.pid
failed_symbols.txt

# Flutter plugins file
.flutter-plugins

# Local configuration
android/local.properties
ios/.bundle/
ios/Pods/
ios/Podfile.lock

# Generated files
# NOTE: Drift database files are tracked because they're critical for CI
# and build_runner can be flaky in CI environments
*.freezed.dart
*.mocks.dart
lib/generated/
# Exclude most generated files except database
lib/**/*.g.dart
!lib/data/database/app_database.g.dart

# Keystore and signing
*.jks
*.keystore
android/key.properties

# macOS
macos/Pods/
macos/Podfile.lock

# Coverage
coverage/
*.lcov

# FVM (Flutter Version Management)
.fvm/
.fvmrc

# Melos
.melos/

# Fastlane
*/fastlane/report.xml
*/fastlane/Preview.html
*/fastlane/screenshots
*/fastlane/test_output

# Firebase
google-services.json
GoogleService-Info.plist
firebase_options.dart

# Generated localization
lib/l10n/
*.arb.dart

# Secrets (add your secret files here)
secrets/
*.pem
*.p12

# VS Code workspace files
*.code-workspace
tool/.calibrate.lock/

# Brainstorming visual companion mockups (local only)
.superpowers/
